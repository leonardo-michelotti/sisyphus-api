# Copie para .env e ajuste conforme necessário. Todas as vars têm prefixo SISYPHUS_.

# Fontes (padrões já apontam para as APIs corretas)
# SISYPHUS_WIKIQUOTE_API=https://pt.wikiquote.org/w/api.php
# SISYPHUS_WIKIDATA_API=https://www.wikidata.org/w/api.php

# Identificação nas chamadas às APIs Wikimedia (boa cidadania — inclua contato)
SISYPHUS_USER_AGENT=sisyphus/0.1 (https://github.com/leonardo-michelotti/sisyphus-api)

# Rede e cache
SISYPHUS_HTTP_TIMEOUT=10.0
SISYPHUS_CACHE_TTL=86400
SISYPHUS_CACHE_MAXSIZE=512

# App
SISYPHUS_CORS_ORIGINS=["*"]
SISYPHUS_LOG_LEVEL=INFO
SISYPHUS_DEBUG=false
